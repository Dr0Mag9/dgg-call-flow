# Server
NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# Database — PostgreSQL (production / recommended local via Docker)
# Example local: postgresql://callflow:callflow@localhost:5432/callflow
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/callflow"

# Auth
JWT_SECRET="change-me-to-a-long-random-string-at-least-16-chars"
JWT_EXPIRES_IN=24h
# Required for `npm run prisma:seed` (admin account is created/updated with this password)
ADMIN_SEED_PASSWORD="Mag#1101"

# Comma-separated browser origins (REST + Socket.IO)
# Local Vite + production VPS frontend
CLIENT_ORIGINS="http://localhost:5173,http://69.62.79.9,https://69.62.79.9"

# Optional: protect POST /api/calls/inbound (telephony webhook) when set
# INBOUND_WEBHOOK_SECRET=""

# Optional: simulation delay for outbound auto-connect (ms), 0 to disable
OUTBOUND_SIMULATE_CONNECT_MS=3000
